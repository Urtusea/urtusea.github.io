---
const {
    class: classProp
} = Astro.props

//If you want to change the responsive height of footer:
//tweak the `[--footer-height:${x}]` classes inside of footer component
---

<footer class:list={[
    classProp,
    "[--footer-height:6] h-[calc(var(--block-size)*var(--footer-height))] xs:[--footer-height:5] sm:[--footer-height:4] md:[--footer-height:3] w-full bg-block-bedrock"
]}>
    <div class="flex flex-col sm:flex-row items-center justify-between h-full p-5 bg-dark-75 text-white">
        <header class="flex flex-col gap-3 w-full sm:w-[60%]">
            <p class="text-sm">Copyright © 2024 by Urtusea. All Rights Reserved</p>
        </header>
    </div>
</footer>
